    <div class="wave-container">
        <svg class="wave wave1" viewBox="0 0 1440 320" preserveAspectRatio="none">
            <path fill="#ffffff"
                  d="M0,160L80,149C160,138,320,117,480,117C640,117,800,149,960,170C1120,192,1280,203,1440,160L1440,320L0,320Z" />
        </svg>

        <svg class="wave wave2" viewBox="0 0 1440 320" preserveAspectRatio="none">
            <path fill="#ffffff"
                  d="M0,160L80,149C160,138,320,117,480,117C640,117,800,149,960,170C1120,192,1280,203,1440,160L1440,320L0,320Z" />
        </svg>
    </div>
</section>
<!-- ABOUT -->
<section id="about">
    <div class="container about-grid reveal">
        <div class="about-image" />
        <div class="about-text">
            <h2>Our Story</h2>
            <p> Established in 2018, Sweet Crumbs Cake House began with a simple mission: to create cakes that bring people together. Every recipe is carefully crafted using premium butter, fresh cream, and high-quality ingredients. Today we proudly serve hundreds of happy customers throughout the region. </p>
        </div>
    </div>
</section>
<!-- PRODUCTS -->
<section class="products" id="cakes">
    <div class="container reveal">
        <div class="section-title">
            <h2>Featured Cakes</h2>
        </div>
        <div class="cards">
            <div class="card">
                <img src="https://images.unsplash.com/photo-1578985545062-69928b1d9587">
                <div class="card-body">
                    <h3>Classic Chocolate Cake</h3>
                    <p>Rich chocolate sponge layered with silky ganache.</p>
                </div>
            </div>
            <div class="card">
                <img src="https://images.unsplash.com/photo-1464349095431-e9a21285b5f3">
                <div class="card-body">
                    <h3>Strawberry Delight</h3>
                    <p>Fresh strawberries and whipped cream perfection.</p>
                </div>
            </div>
            <div class="card">
                <img src="https://images.unsplash.com/photo-1563729784474-d77dbb933a9e">
                <div class="card-body">
                    <h3>Wedding Collection</h3>
                    <p>Elegant multi-tier masterpieces for your big day.</p>
                </div>
            </div>
            <div class="card">
                <img src="https://images.unsplash.com/photo-1486427944299-d1955d23e34d">
                <div class="card-body">
                    <h3>Birthday Specials</h3>
                    <p>Custom themed cakes for unforgettable celebrations.</p>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- TESTIMONIALS -->
<section class="testimonials" id="reviews">

    <div class="parallax-bg"></div>

    <div class="overlay"></div>


    <div class="container reveal">
        <div class="section-title">
            <h2>What Customers Say</h2>
        </div>
        <div class="review-grid">
            <div class="review">
                <p> The best chocolate cake I've ever tasted. Moist, rich and beautifully decorated. </p>
                <strong>— Sarah</strong>
            </div>
            <div class="review">
                <p> Ordered our wedding cake here and everyone loved it. Stunning design and amazing flavour. </p>
                <strong>— Daniel & Emma</strong>
            </div>
            <div class="review">
                <p> Reliable, professional and always fresh. Our family's favourite cake shop. </p>
                <strong>— Mr. Lim</strong>
            </div>
        </div>
    </div>
</section>
<!-- CONTACT -->
<section class="contact" id="contact">
    <div class="container reveal">
        <h2>Visit Sweet Crumbs</h2>
        <p> 📍 25 Baker Street<br> Kuala Lumpur, Malaysia </p>
        <p> 📞 +60 12-345 6789 </p>
        <p> ✉ hello@sweetcrumbs.com </p>
    </div>
</section>

@code {
   

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("eval", "window.dispatchEvent(new Event('load'))");
            await JS.InvokeVoidAsync("initializeScrollReveal");
            await JS.InvokeVoidAsync("initializeParallax");
        }
    }
}