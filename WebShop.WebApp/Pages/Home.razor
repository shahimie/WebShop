@page "/"
@inject IJSRuntime JS

<PageTitle>Home</PageTitle>


<nav>
    <div class="nav-container" id="navContainer">
        <a href="#home" data-target="home">Home</a>
        <a href="#about" data-target="about">About</a>
        <a href="#cakes" data-target="cakes">Cakes</a>
        <a href="#reviews" data-target="reviews">Reviews</a>
        <a href="#contact" data-target="contact">Contact</a>

        <div class="nav-indicator" id="navIndicator"></div>
    </div>
</nav>

<!-- HERO -->
<section class="hero" id="home">
    <div class="hero-content reveal">
        <h1>Sugar</h1>
        <h6>Sweet.Cakes.Coffee</h6>
        <p> Handcrafted cakes baked fresh every day. From elegant wedding cakes to delightful birthday creations, every slice is made with passion and premium ingredients. </p>
        <a href="#cakes" class="btn"> Explore Our Cakes </a>
    </div>
